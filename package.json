{
  "name": "did-resolver",
  "version": "4.1.0",
  "description": "Resolve DID documents",
  "source": "src/resolver.ts",
  "main": "./lib/resolver.cjs",
  "module": "./lib/resolver.mjs",
  "types": "./lib/resolver.d.ts",
  "files": [
    "lib",
    "src",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./lib/resolver.d.cts",
        "default": "./lib/resolver.cjs"
      },
      "import": {
        "types": "./lib/resolver.d.mts",
        "default": "./lib/resolver.mjs"
      }
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/decentralized-identity/did-resolver.git"
  },
  "author": "Pelle Braendgaard",
  "contributors": [
    "Mircea Nistor <work@mirceanis.xyz>",
    "Jack Tanner <jack+public@tonomy.foundation>",
    "Rebal Alhaqash <rebal@tonomy.foundation>"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf lib",
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/postbuild.mjs",
    "format": "prettier --write \"src/**/*.[jt]s\"",
    "lint": "eslint \"src/**/*.[jt]s\"",
    "release": "semantic-release --debug"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.8.3",
    "semantic-release": "19.0.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
